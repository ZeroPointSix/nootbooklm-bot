{
  "$schema": "https://raw.githubusercontent.com/slackapi/manifest-schema/main/manifest.schema.json",
  "display_information": {
    "name": "NotebookLM Research Agent",
    "description": "在 Slack 中使用 NotebookLM 进行资料研究"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "NotebookLM Agent",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "连接 NotebookLM，添加资料、提问、总结和比较研究结论。",
      "suggested_prompts": []
    },
    "slash_commands": [
      {
        "command": "/notebook",
        "description": "管理 NotebookLM 登录与状态",
        "usage_hint": "login | status | logout | help",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "im:history",
        "chat:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "assistant_thread_started",
        "message.im",
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
